[env:esp32s3-n16r8]
build_flags =
    ${env.build_flags}
    -DWIFI_SSID=\"your-ssid\"
    -DWIFI_PASSWORD=\"your-password\"
    -DMQTT_BROKER_IP=\"192.168.x.x\"
